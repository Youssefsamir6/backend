# Smart Access Backend Env

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smart-access

# Backend
PORT=3000

# AI Worker
AI_URL=http://localhost:5000

# Device Auth (JSON array of strings)
DEVICE_API_KEYS=[\"dev-key-123\", \"cam-main-456\", \"cam-side-789\"]

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=app-password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-me

# Run:
# Backend: npm start
# AI Worker: cd ai-worker && pip install -r requirements.txt && python app.py
# Camera: cd ai-worker && python camera_worker.py

# Test device:
# curl -X POST http://localhost:3000/api/ai/device/smart-access \\
#   -H \"X-API-Key: dev-key-123\" \\
#   -F \"image=@test.jpg\" \\
#   -F \"deviceId=cam-main\" \\
#   -F \"gateName=Main Gate\"

